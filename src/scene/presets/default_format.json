{
  "version": "1.0",
  "name": "默认格式",
  "description": "默认排版方案",
  "category": "thesis",
  "category_label": "学位论文",
  "capabilities": {
    "heading_numbering": true,
    "section_detection": true,
    "caption": true,
    "header_footer": true,
    "toc_rebuild": true,
    "equation_numbering": true,
    "md_cleanup": true,
    "whitespace_normalize": true,
    "citation_link_restore": true,
    "chem_typography_restore": true
  },
  "available_sections": [
    "body",
    "references",
    "errata",
    "acknowledgment",
    "appendix",
    "resume",
    "abstract_cn",
    "abstract_en",
    "toc"
  ],
  "page_setup": {
    "paper_size": "A4",
    "margin": {
      "top_cm": 3.8,
      "bottom_cm": 3.8,
      "left_cm": 3.2,
      "right_cm": 3.2
    },
    "gutter_cm": 0.0,
    "header_distance_cm": 3.0,
    "footer_distance_cm": 3.0
  },
  "heading_numbering": {
    "mode": "B",
    "scheme": "2",
    "levels": {
      "heading1": {
        "format": "chinese_chapter",
        "template": "第{cn}章",
        "separator": "　",
        "custom_separator": null,
        "alignment": "center",
        "left_indent_chars": 0.0
      },
      "heading2": {
        "format": "chinese_section",
        "template": "第{cn}节",
        "separator": "　",
        "custom_separator": null,
        "alignment": "center",
        "left_indent_chars": 0.0
      },
      "heading3": {
        "format": "chinese_ordinal",
        "template": "{cn}、",
        "separator": "　",
        "custom_separator": null,
        "alignment": "left",
        "left_indent_chars": 2.0
      },
      "heading4": {
        "format": "chinese_ordinal_paren",
        "template": "（{cn}）",
        "separator": "　",
        "custom_separator": null,
        "alignment": "left",
        "left_indent_chars": 2.0
      }
    },
    "schemes": {
      "1": {
        "heading1": {
          "format": "arabic",
          "template": "{n}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        },
        "heading2": {
          "format": "arabic_dotted",
          "template": "{parent}.{n}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        },
        "heading3": {
          "format": "arabic_dotted",
          "template": "{parent}.{n}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        },
        "heading4": {
          "format": "arabic_dotted",
          "template": "{parent}.{n}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        }
      },
      "2": {
        "heading1": {
          "format": "chinese_chapter",
          "template": "第{cn}章",
          "separator": "　",
          "custom_separator": null,
          "alignment": "center",
          "left_indent_chars": 0.0
        },
        "heading2": {
          "format": "chinese_section",
          "template": "第{cn}节",
          "separator": "　",
          "custom_separator": null,
          "alignment": "center",
          "left_indent_chars": 0.0
        },
        "heading3": {
          "format": "chinese_ordinal",
          "template": "{cn}、",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 2.0
        },
        "heading4": {
          "format": "chinese_ordinal_paren",
          "template": "（{cn}）",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 2.0
        }
      }
    },
    "enforcement": {
      "ban_tab": true,
      "ban_double_halfwidth_space": true,
      "ban_mixed_separator_per_level": true,
      "auto_fix": true
    },
    "risk_guard": {
      "enabled": true,
      "no_body_min_candidates": 2,
      "no_body_min_chapters": 1,
      "no_chapter_min_outside_chapters": 1,
      "tiny_body_max_abs_paras": 4,
      "tiny_body_max_ratio": 0.08,
      "tiny_body_min_candidates": 2,
      "tiny_body_primary_margin": 1,
      "keep_after_first_chapter": true
    }
  },
  "heading_model": {
    "level_to_word_style": {
      "heading1": "Heading 1",
      "heading2": "Heading 2",
      "heading3": "Heading 3",
      "heading4": "Heading 4",
      "heading5": "Heading 5",
      "heading6": "Heading 6",
      "heading7": "Heading 7",
      "heading8": "Heading 8"
    },
    "level_to_style_key": {
      "heading1": "heading1",
      "heading2": "heading2",
      "heading3": "heading3",
      "heading4": "heading4",
      "heading5": "heading5",
      "heading6": "heading6",
      "heading7": "heading7",
      "heading8": "heading8"
    },
    "style_alias_to_level": {
      "一级标题": "heading1",
      "二级标题": "heading2",
      "三级标题": "heading3",
      "四级标题": "heading4",
      "五级标题": "heading5",
      "六级标题": "heading6",
      "七级标题": "heading7",
      "八级标题": "heading8",
      "章标题": "heading1",
      "节标题": "heading2",
      "标题 1": "heading1",
      "标题 2": "heading2",
      "标题 3": "heading3",
      "标题 4": "heading4"
    },
    "section_title_style_map": {
      "abstract_cn": "abstract_title_cn",
      "abstract_en": "abstract_title_en",
      "references": "heading1",
      "errata": "heading1",
      "appendix": "heading1",
      "acknowledgment": "heading1",
      "resume": "heading1"
    },
    "non_numbered_title_sections": [
      "references",
      "errata",
      "appendix",
      "acknowledgment",
      "resume"
    ],
    "non_numbered_title_texts": [
      "参考文献",
      "勘误页",
      "勘误",
      "致谢",
      "个人简历",
      "在学期间发表的学术论文与研究成果",
      "附录"
    ],
    "front_matter_title_texts": [
      "摘要",
      "摘要。",
      "摘要：",
      "摘要:",
      "abstract",
      "目录",
      "目录：",
      "tableofcontents"
    ],
    "post_section_types": [
      "references",
      "errata",
      "appendix",
      "acknowledgment",
      "resume"
    ],
    "non_numbered_heading_style_name": "Heading 1 Unnumbered",
    "header_front_text": {
      "abstract_cn": "摘要",
      "abstract_en": "Abstract",
      "toc": "目录"
    },
    "header_back_types": [
      "references",
      "errata",
      "acknowledgment",
      "appendix",
      "resume"
    ]
  },
  "caption": {
    "enabled": true,
    "auto_insert": true,
    "format_inserted": false,
    "figure_prefix": "图",
    "table_prefix": "表",
    "separator": "　",
    "placeholder": "[待补充]",
    "numbering_format": "chapter.seq"
  },
  "chem_typography": {
    "enabled": true,
    "scopes": {
      "references": true,
      "body": false,
      "headings": false,
      "abstract_cn": false,
      "abstract_en": false
    },
    "allow_tokens": [],
    "allow_patterns": [],
    "ignore_tokens": [],
    "ignore_patterns": [],
    "manual_overrides": {}
  },
  "whitespace_normalize": {
    "enabled": false,
    "normalize_space_variants": true,
    "convert_tabs": true,
    "remove_zero_width": true,
    "collapse_multiple_spaces": true,
    "trim_paragraph_edges": true,
    "smart_full_half_convert": true,
    "punctuation_by_context": true,
    "bracket_by_inner_language": true,
    "fullwidth_alnum_to_halfwidth": true,
    "quote_by_context": false,
    "protect_reference_numbering": true,
    "context_min_confidence": 2
  },
  "citation_link": {
    "enabled": false,
    "auto_number_reference_entries": true,
    "superscript_outer_page_numbers": false
  },
  "format_scope": {
    "mode": "auto",
    "body_start_index": null,
    "body_start_page": null,
    "body_start_keyword": "",
    "sections": {
      "body": true,
      "references": true,
      "errata": true,
      "acknowledgment": true,
      "appendix": true,
      "abstract_cn": true,
      "abstract_en": true,
      "toc": true,
      "resume": true,
      "cover": false
    }
  },
  "normal_table_layout_mode": "smart",
  "normal_table_smart_levels": 4,
  "normal_table_border_mode": "three_line",
  "table_border_width_pt": 0.5,
  "three_line_header_width_pt": 1.0,
  "three_line_bottom_width_pt": 0.5,
  "normal_table_line_spacing_mode": "single",
  "normal_table_repeat_header": false,
  "update_header": true,
  "update_page_number": true,
  "update_header_line": true,
