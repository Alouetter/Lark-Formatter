      },
      "paren_cn": {
        "label": "（{}）",
        "prefix": "（",
        "suffix": "）"
      },
      "paren_en": {
        "label": "({})",
        "prefix": "(",
        "suffix": ")"
      },
      "appendix_cn": {
        "label": "附录{}",
        "prefix": "附录",
        "suffix": ""
