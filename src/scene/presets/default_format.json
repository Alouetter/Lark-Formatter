{
  "version": "1.0",
  "name": "默认格式",
  "description": "默认排版方案",
  "category": "thesis",
  "category_label": "学位论文",
  "capabilities": {
    "heading_numbering": true,
    "section_detection": true,
    "caption": true,
    "header_footer": true,
    "toc_rebuild": true,
    "equation_numbering": true,
    "md_cleanup": true,
    "whitespace_normalize": true,
    "citation_link_restore": true,
    "chem_typography_restore": true
  },
  "available_sections": [
    "body",
    "references",
    "errata",
    "acknowledgment",
    "appendix",
    "resume",
    "abstract_cn",
    "abstract_en",
    "toc"
  ],
  "page_setup": {
    "paper_size": "A4",
    "margin": {
      "top_cm": 3.8,
      "bottom_cm": 3.8,
      "left_cm": 3.2,
      "right_cm": 3.2
    },
    "gutter_cm": 0.0,
    "header_distance_cm": 3.0,
    "footer_distance_cm": 3.0
  },
  "heading_numbering": {
    "mode": "B",
    "scheme": "2",
    "levels": {
      "heading1": {
        "format": "chinese_chapter",
        "template": "第{current}章",
        "separator": "　",
        "custom_separator": null,
        "alignment": "",
        "left_indent_chars": 0
      },
      "heading2": {
        "format": "chinese_section",
        "template": "第{current}节",
        "separator": "　",
        "custom_separator": null,
        "alignment": "",
        "left_indent_chars": 0
      },
      "heading3": {
        "format": "chinese_ordinal",
        "template": "{current}、",
        "separator": "　",
        "custom_separator": null,
        "alignment": "",
        "left_indent_chars": 0
      },
      "heading4": {
        "format": "chinese_ordinal_paren",
        "template": "（{current}）",
        "separator": "　",
        "custom_separator": null,
        "alignment": "",
        "left_indent_chars": 0
      }
    },
    "schemes": {
      "1": {
        "heading1": {
          "format": "arabic",
          "template": "{current}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        },
        "heading2": {
          "format": "arabic_dotted",
          "template": "{level1}.{current}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        },
        "heading3": {
          "format": "arabic_dotted",
          "template": "{level1}.{level2}.{current}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        },
        "heading4": {
          "format": "arabic_dotted",
          "template": "{level1}.{level2}.{level3}.{current}",
          "separator": "　",
          "custom_separator": null,
          "alignment": "left",
          "left_indent_chars": 0
        }
      },
      "2": {
        "heading1": {
          "format": "chinese_chapter",
          "template": "第{current}章",
          "separator": "　",
          "custom_separator": null,
          "alignment": "",
          "left_indent_chars": 0
        },
        "heading2": {
          "format": "chinese_section",
          "template": "第{current}节",
          "separator": "　",
          "custom_separator": null,
          "alignment": "",
          "left_indent_chars": 0
        },
        "heading3": {
          "format": "chinese_ordinal",
          "template": "{current}、",
          "separator": "　",
          "custom_separator": null,
          "alignment": "",
          "left_indent_chars": 0
        },
        "heading4": {
          "format": "chinese_ordinal_paren",
          "template": "（{current}）",
          "separator": "　",
          "custom_separator": null,
          "alignment": "",
          "left_indent_chars": 0
        }
      }
    },
    "enforcement": {
      "ban_tab": true,
      "ban_double_halfwidth_space": true,
      "ban_mixed_separator_per_level": true,
      "auto_fix": true
    },
    "risk_guard": {
      "enabled": true,
      "no_body_min_candidates": 2,
      "no_body_min_chapters": 1,
      "no_chapter_min_outside_chapters": 1,
      "tiny_body_max_abs_paras": 4,
      "tiny_body_max_ratio": 0.08,
      "tiny_body_min_candidates": 2,
      "tiny_body_primary_margin": 1,
      "keep_after_first_chapter": true
    }
  },
  "heading_numbering_v2": {
    "enabled": true,
    "shell_catalog": {
      "plain": {
        "label": "{}",
        "prefix": "",
        "suffix": ""
      },
      "dot_suffix": {
        "label": "{}.",
        "prefix": "",
        "suffix": "."
